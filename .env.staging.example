APP_ENV=staging
FLASK_ENV=staging
DATABASE_URL=sqlite:////home/lighthouse/tianji-staging/backend/tianji.db
UPLOAD_FOLDER=/var/www/xuan-cet-staging/static/uploads
OAUTH_ORIGIN=http://119.29.128.18:8081
PUBLIC_BASE_URL=http://119.29.128.18:8081

# 测试环境默认只写日志，不真实触达用户。
STAGING_SMS_MODE=log
STAGING_SMS_WHITELIST=
STAGING_EMAIL_MODE=log
STAGING_EMAIL_WHITELIST=
STAGING_PAYMENT_MODE=manual

# 虎皮椒测试支付默认关闭。需要联调时只在服务器环境变量或受控 .env 中填写真实值。
HUPIJIAO_ENABLED=0
HUPIJIAO_APPID=
HUPIJIAO_APPSECRET=
# HUPIJIAO_GATEWAY_URL=https://api.xunhupay.com/payment/do.html

# 如需只给自己的手机号/邮箱真实发送，可改为：
# STAGING_SMS_MODE=send
# STAGING_SMS_WHITELIST=13800000000
# STAGING_EMAIL_MODE=send
# STAGING_EMAIL_WHITELIST=you@example.com
